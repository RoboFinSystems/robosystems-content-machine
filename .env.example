# =============================================================================
# ROBOSYSTEMS CONTENT MACHINE — Environment Configuration
# =============================================================================
#
# SETUP: cp .env.example .env
#        Then fill in your API keys below.
#
# =============================================================================

# ElevenLabs - Voice synthesis
ELEVEN_LABS_API_KEY=your-elevenlabs-api-key-here
ELEVEN_LABS_VOICE_ID=your-elevenlabs-voice-id
# Optional: second voice for the Q&A podcast interviewer (host).
# If unset, the Q&A tool auto-picks a premade voice (default: "Sarah").
# ELEVEN_LABS_INTERVIEWER_VOICE_ID=

# Shotstack - Video assembly (production)
SHOTSTACK_OWNER_ID=your-shotstack-owner-id
SHOTSTACK_API_KEY=your-shotstack-api-key-here
SHOTSTACK_ENV=v1

# Shotstack - Video assembly (sandbox)
SHOTSTACK_OWNER_ID_SANDBOX=your-shotstack-sandbox-owner-id
SHOTSTACK_API_KEY_SANDBOX=your-shotstack-sandbox-api-key-here
SHOTSTACK_ENV_SANDBOX=stage

# Pipeline options
# SUBTITLES: true | false — burn in Whisper-timed captions
SUBTITLES=false

# AWS - Used by assemble step for S3 uploads
AWS_PROFILE=your-aws-profile
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
