# =============================================================================
# ROBOSYSTEMS CONTENT MACHINE — Environment Configuration
# =============================================================================
#
# SETUP: cp .env.example .env
#        Then fill in your API keys below.
#
# =============================================================================

# ElevenLabs - Voice synthesis
ELEVEN_LABS_API_KEY=your-elevenlabs-api-key-here
ELEVEN_LABS_VOICE_ID=your-elevenlabs-voice-id
# Optional: second voice for the Q&A podcast interviewer (host).
# If unset, the Q&A tool auto-picks a premade voice (default: "Sarah").
# ELEVEN_LABS_INTERVIEWER_VOICE_ID=

# Shotstack - Video assembly (production)
SHOTSTACK_OWNER_ID=your-shotstack-owner-id
SHOTSTACK_API_KEY=your-shotstack-api-key-here
SHOTSTACK_ENV=v1

# Shotstack - Video assembly (sandbox)
SHOTSTACK_OWNER_ID_SANDBOX=your-shotstack-sandbox-owner-id
SHOTSTACK_API_KEY_SANDBOX=your-shotstack-sandbox-api-key-here
SHOTSTACK_ENV_SANDBOX=stage

# Pipeline options
# SUBTITLES: true | false — burn in Whisper-timed captions
SUBTITLES=false

# AWS - S3 artifact store + CloudFront CDN for published content
# AWS_PROFILE / AWS_REGION drive the aws CLI used by the assemble + publish steps and by
# `just infra-deploy` (cloudformation/marketing.yaml). AWS_S3_BUCKET is the marketing bucket.
# AWS_CDN_DOMAIN_URL is the public base URL the catalog + briefs are served from: set it to
# the CloudFront custom domain once the marketing stack is deployed (e.g.
# https://assets.robosystems.ai); leave blank to fall back to
# https://<AWS_S3_BUCKET>.s3.amazonaws.com.
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_CDN_DOMAIN_URL=
# Route53 hosted zone id for the CDN domain. Optional — `just infra-deploy` auto-resolves it
# from AWS_CDN_DOMAIN_URL's domain; set this only to override (e.g. a delegated subdomain zone).
AWS_ROUTE53_HOSTED_ZONE_ID=

# YouTube - channel id for `just sync-youtube` (title-matches the channel RSS feed to
# capture video/podcast URLs into the research catalog so the portal embeds YouTube).
# Find it: open your channel (e.g. youtube.com/@yourhandle) and grab the "UC..." id from
# the page source / a channel/UC... URL. No API key needed — the feed is public.
YT_CHANNEL_ID=your-youtube-channel-id
