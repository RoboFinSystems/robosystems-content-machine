# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Unit test / coverage reports
.pytest_cache/
.coverage
htmlcov/

# Environments
.env
.env.local
.env.*.local
.envrc
.venv
venv/

# Project outputs (generated per-project)
projects/*/

# Drafts — WIP staging + editorial layer: fully ignored (kept private, like the design-doc
# vault). Holds the thought-leadership campaign (brief/calendar/ideas) + churny WIP content;
# pieces graduate to blog/ or post natively. Nothing here is versioned in the public repo.
drafts/

# Campaign shared sources (may contain third-party data)
campaigns/*/sources/

# Local (untracked scratch space)
local/

# Shared media libraries — track the manifests, not the heavy binaries
assets/broll/*.mp4
assets/broll/*.mov
assets/music/*.mp3
assets/music/*.wav

# Blog: track the prose (post.md) + authored cover/social; ignore generated artifacts
# (narration is regenerable via `just blog-narrate` and lives in S3 after publish)
blog/*/*_narration.mp3
blog/*/*_postpack.md

# MacOS
.DS_Store

# IDE
.vscode/
.idea/

# AI - Claude Code
.claude/settings.local.json
CLAUDE.local.md

# Ruff cache
.ruff_cache/

# Obsidian vault
.obsidian/
