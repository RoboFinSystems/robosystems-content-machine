# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Unit test / coverage reports
.pytest_cache/
.coverage
htmlcov/

# Environments
.env
.env.local
.env.*.local
.envrc
.venv
venv/

# Project outputs (generated per-project)
projects/*/

# Campaign shared sources (may contain third-party data)
campaigns/*/sources/

# Local (untracked scratch space)
local/

# Shared media libraries — track the manifests, not the heavy binaries
assets/broll/*.mp4
assets/broll/*.mov
assets/music/*.mp3
assets/music/*.wav

# MacOS
.DS_Store

# IDE
.vscode/
.idea/

# AI - Claude Code
.claude/settings.local.json
CLAUDE.local.md

# Ruff cache
.ruff_cache/
