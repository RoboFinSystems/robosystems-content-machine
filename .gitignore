# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Unit test / coverage reports
.pytest_cache/
.coverage
htmlcov/

# Environments
.env
.env.local
.env.*.local
.envrc
.venv
venv/

# Project outputs (generated per-project)
projects/*/

# Drafts — WIP staging + editorial layer: fully ignored (kept private, like the design-doc
# vault). Holds the thought-leadership campaign (brief/calendar/ideas) + churny WIP content;
# pieces graduate to blog/ or post natively. Nothing here is versioned in the public repo.
drafts/

# Campaign shared sources (may contain third-party data)
campaigns/*/sources/

# Local (untracked scratch space)
local/

# Shared media libraries — track the manifests, not the heavy binaries
assets/broll/*.mp4
assets/broll/*.mov
assets/music/*.mp3
assets/music/*.wav
assets/backgrounds/*.png
assets/backgrounds/*.jpg
assets/backgrounds/*.jpeg
assets/backgrounds/*.webp

# Blog: ONLY the prose (post.md) is versioned. Everything else in a post folder —
# social copy, narration mp3, postpack, cover — stays local (and lives on S3 after publish).
blog/*/*
!blog/*/post.md

# MacOS
.DS_Store

# IDE
.vscode/
.idea/

# AI - Claude Code
.claude/settings.local.json
CLAUDE.local.md

# Ruff cache
.ruff_cache/

# Obsidian vault
.obsidian/

# Showcase = per-episode demo products (scene specs, captures, renders) authored via
# Claude Code. Company folders match the backend demo slugs (e.g. coffee_roaster,
# saas_startup). Products, not tooling — gitignored; only renderer/ (the tool) is committed.
showcase/
